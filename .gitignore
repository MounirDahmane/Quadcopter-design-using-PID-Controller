# PlatformIO Build Artifacts
# These directories are generated during build and should not be committed
.pio/

# Visual Studio Code Configuration
# Exclude generated IntelliSense database and build info
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/

# Build Artifacts
# Remove any compiled binaries or intermediate files
*.apk

# SECURITY: WiFi Credentials
# NOTE: secret.h contains sensitive WiFi passwords and MUST NOT be committed
# Create a local copy with your credentials and add to gitignore
secret.h

# IDE-Specific Files
.vscode/
.idea/
*.swp
*.swo

# OS-Specific Files
.DS_Store
Thumbs.db
.env
.env.local

# Build Output
build/
dist/

# Python Cache (if using Python scripts)
__pycache__/
*.py[cod]
*$py.class